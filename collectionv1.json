  "item": [
    {
      "name": "Get List of Users (Page 2)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Kiểm tra tất cả các khía cạnh của response GET users",
              "",
              "// Test 1: Status code phải là 200 OK",
              "pm.test(\"Status code là 200\", function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "// Test 2: Response time phải nhanh (API đơn giản nên yêu cầu dưới 2 giây)",
              "pm.test(\"Response time dưới 2000ms\", function() {",
              "  pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// Test 3: Parse JSON và kiểm tra cấu trúc dữ liệu",
              "pm.test(\"Response body có cấu trúc pagination đúng\", function() {",
              "  // Parse response body thành JavaScript object",
              "  const body = pm.response.json();",
              "",
              "  // Kiểm tra các field pagination tồn tại và đúng kiểu",
              "  pm.expect(body.page).to.eql(2);          // Page hiện tại phải là 2",
              "  pm.expect(body.per_page).to.be.a('number'); // per_page phải là số",
              "  pm.expect(body.total).to.be.a('number');    // total users phải là số",
              "  pm.expect(body.total_pages).to.be.above(0); // Phải có ít nhất 1 trang",
              "});",
              "",
              "// Test 4: Kiểm tra data array hợp lệ",
              "pm.test(\"Data array chứa danh sách users hợp lệ\", function() {",
              "  const body = pm.response.json();",
              "",
              "  // data phải là array và không rỗng",
              "  pm.expect(body.data).to.be.an('array');",
              "  pm.expect(body.data.length).to.be.above(0);",
              "",
              "  // Kiểm tra mỗi user trong array có đầy đủ fields",
              "  body.data.forEach(function(user) {",
              "    pm.expect(user).to.have.property('id');           // Phải có id",
              "    pm.expect(user).to.have.property('email');        // Phải có email",
              "    pm.expect(user).to.have.property('first_name');   // Phải có first_name",
              "    pm.expect(user).to.have.property('last_name');    // Phải có last_name",
              "    pm.expect(user.email).to.include('@');            // Email phải có dấu @",
              "  });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
