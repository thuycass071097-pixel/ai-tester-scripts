    {
      "name": "Login Successful",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"eve.holt@reqres.in\",\n  \"password\": \"cityslicka\"\n}"
        },
        "url": {
          "raw": "https://reqres.in/api/login",
          "protocol": "https",
          "host": ["reqres", "in"],
          "path": ["api", "login"]
        }
      },
      "response": [],
